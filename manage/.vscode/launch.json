  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch yarn watch",
      "request": "launch",
      "runtimeArgs": ["watch"],
      "runtimeExecutable": "yarn",
      "skipFiles": ["<node_internals>/**"],
      "type": "node"
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "Launch Chrome against localhost",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}"
    }
  ]
}