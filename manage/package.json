{
  "name": "chemi_manage",
  "description": "a chemical management system",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "license": "",
  "packageManager": "yarn@3.2.3",
  "scripts": {
    "build:tailwind": "tailwind build -i src/tailwind.css -o src/tailwind.output.css",
    "watch:tailwind": "npm run build:tailwind -- --watch",
    "watch": "npm-run-all build:tailwind --parallel watch:tailwind dev",
    "prebuild": "run-s build:tailwind",
    "dev": "vite",
    "start": "vite --host 0.0.0.0",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "serve": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@emotion/react": "^11.10.5",
    "@emotion/styled": "^11.10.5",
    "clsx": "^1.2.1",
    "d3": "^7.8.0",
    "date-fns": "^2.29.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-resize-detector": "^7.1.2",
    "react-router-dom": "^6.6.1",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@types/d3": "^7.4.0",
    "@types/node": "^18.11.18",
    "@types/react": "^18.0.26",
    "@types/react-dom": "^18.0.10",
    "@vitejs/plugin-react": "^3.0.1",
    "autoprefixer": "^10.4.13",
    "eslint-config-prettier": "^8.6.0",
    "eslint-plugin-prettier": "^4.2.1",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.21",
    "prettier": "^2.8.2",
    "tailwindcss": "^3.2.4",
    "typescript": "^4.9.4",
    "vite": "^4.0.4"
  }
}
